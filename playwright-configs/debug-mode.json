{
  "name": "调试模式",
  "description": "可视化浏览器，用于开发和调试爬虫脚本",
  "browser": "chrome",
  "headless": false,
  "viewport": {
    "width": 1600,
    "height": 900
  },
  "timeout": {
    "navigation": 120000,
    "action": 30000
  },
  "output": {
    "dir": "./playwright-output/debug",
    "save_session": true,
    "save_trace": true,
    "save_video": "1280x720"
  },
  "user_data_dir": "./playwright-data/debug-profile",
  "slow_mo": 500,
  "description_note": "slow_mo参数让每个操作延迟500ms，方便观察"
}