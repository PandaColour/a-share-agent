{
  "name": "财经新闻抓取器",
  "description": "用于抓取东方财富、同花顺等网站的股票新闻和公告",
  "browser": "chrome",
  "headless": true,
  "viewport": {
    "width": 1920,
    "height": 1080
  },
  "timeout": {
    "navigation": 30000,
    "action": 10000
  },
  "output": {
    "dir": "./playwright-output/news",
    "save_session": true,
    "save_trace": false
  },
  "allowed_hosts": [
    "eastmoney.com",
    "10jqka.com.cn",
    "sina.com.cn",
    "xueqiu.com",
    "cnstock.com"
  ],
  "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
}